<Window x:Class="RefitDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        Title="Refit Demo - Posts"
        Width="900"
        Height="500"
        mc:Ignorable="d">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadPostsCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <DockPanel Margin="10">
        <!-- Error banner -->
        <Border DockPanel.Dock="Top"
                Background="#FFF3CD"
                BorderBrush="#FFEEBA"
                BorderThickness="1"
                Padding="10"
                Margin="0,0,0,10"
                Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#856404"
                       TextWrapping="Wrap" />
        </Border>

        <!-- Loading indicator -->
        <Border DockPanel.Dock="Top"
                Background="#D1ECF1"
                BorderBrush="#BEE5EB"
                BorderThickness="1"
                Padding="10"
                Margin="0,0,0,10"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="Loading posts..."
                       Foreground="#0C5460" />
        </Border>

        <!-- Posts list -->
        <ListBox x:Name="postList"
                 ItemsSource="{Binding Posts}"
                 IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Id}" FontWeight="Bold" />
                        <TextBlock Grid.Column="1"
                                   Margin="10,0"
                                   Foreground="Gray"
                                   Text="{Binding UserId}" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding Title}"
                                   FontWeight="SemiBold" />
                        <TextBlock Grid.Column="3"
                                   Margin="10,0,0,0"
                                   Text="{Binding Body}"
                                   TextTrimming="CharacterEllipsis" />
                        <Button Grid.Column="4"
                                Width="75"
                                Height="30"
                                Margin="10,0,0,0"
                                Content="Delete"
                                Command="{Binding DataContext.DeletePostCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding Id}" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
